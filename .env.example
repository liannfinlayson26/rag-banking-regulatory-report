# Copy this file to .env and fill in your keys. Do NOT commit .env.

# OpenAI — embeddings and/or chat models
OPENAI_API_KEY=your-openai-key-here

# Google Generative AI (Gemini) — chat models via langchain-google-genai
GOOGLE_API_KEY=your-google-key-here

# Tavily — web search for retrieval augmentation
TAVILY_API_KEY=your-tavily-key-here
